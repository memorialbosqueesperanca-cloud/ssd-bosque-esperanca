# --- CONFIGURAÇÕES DO SERVIDOR ---
# Porta onde o nosso 'cérebro' Node.js vai rodar
PORT=3000

# --- INTEGRAÇÃO IVERTEX (LOGÍSTICA) ---
# Aguardando retorno da Giovana para confirmar estes dados
IVERTEX_API_URL=https://api.ivertex.com.br/v1
IVERTEX_TOKEN=AGUARDANDO_GIOVANA

# --- INTEGRAÇÃO BUBBLE.IO (PORTAL MEMORIAL) ---
# Usando version-test para os nossos testes iniciais de desenvolvimento
BUBBLE_API_URL=https://memorialbosque.com.br/version-test/api/1.1/obj/memoriais
BUBBLE_TOKEN=790b4c4a6f1a30fa708f4d328614a691

# --- CONFIGURAÇÕES DO SISTEMA ---
# Tempo (em minutos) para o sistema atualizar as fotos e nomes
CACHE_EXPIRATION_MINUTES=5
